package com.cognizant.ormlearn.repository;

import com.cognizant.ormlearn.model.Country;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.stereotype.Repository;

import java.util.List;

/**
 * CountryRepository – Spring Data JPA repository for Country.
 *
 * Hands-on 1 (doc 1): Quick Example – extends JpaRepository to get
 * built-in CRUD methods without writing any implementation code.
 * This is the key benefit of Spring Data JPA over plain Hibernate.
 *
 * Hands-on 1 (doc 2): Query Methods – Spring Data JPA generates SQL
 * automatically from method names using keywords like:
 *   findBy<Field>Containing  → WHERE co_name LIKE '%?%'
 *   findBy<Field>StartingWith → WHERE co_name LIKE '?%'
 *   OrderBy<Field>Asc        → ORDER BY co_name ASC
 *
 * No SQL or HQL needed — the method name IS the query specification.
 *
 * JpaRepository<Country, String>:
 *   Country = entity type
 *   String  = type of the primary key (co_code is VARCHAR → String)
 *
 * Built-in methods inherited:
 *   findAll(), findById(), save(), deleteById(), count(), existsById()
 */
@Repository
public interface CountryRepository extends JpaRepository<Country, String> {

    // ── Hands-on 1 (doc 2): Query Methods ───────────────────────────────────

    /**
     * Search countries whose name CONTAINS the given text (case-insensitive).
     * Use case: autocomplete search box.
     *
     * Generated SQL: SELECT * FROM country WHERE UPPER(co_name) LIKE UPPER('%text%')
     *
     * Example: findByNameContainingIgnoreCase("ou")
     * Returns: Bouvet Island, Djibouti, Guadeloupe, South Georgia…, Luxembourg, etc.
     */
    List<Country> findByNameContainingIgnoreCase(String text);

    /**
     * Same as above but returns results sorted by name in ascending order.
     * Demonstrates combining filters + sorting in a single method name.
     *
     * Generated SQL: … ORDER BY co_name ASC
     */
    List<Country> findByNameContainingIgnoreCaseOrderByNameAsc(String text);

    /**
     * Countries whose name STARTS WITH the given letter/prefix.
     * Use case: alphabetical index navigation (click 'Z' → show all Z countries).
     *
     * Generated SQL: SELECT * FROM country WHERE co_name LIKE 'Z%'
     *
     * Example: findByNameStartingWith("Z") → Zambia, Zimbabwe
     */
    List<Country> findByNameStartingWith(String prefix);
}
